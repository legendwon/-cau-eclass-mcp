"""
Credential management with Windows DPAPI encryption.
Stores encrypted CAU portal credentials in .claude/.credentials.json
"""

import os
import json
import base64
from pathlib import Path
from typing import Optional, Dict

try:
    import win32crypt
    HAS_DPAPI = True
except ImportError:
    HAS_DPAPI = False
    print("Warning: pywin32 not available, credentials will be stored in plaintext")


class CredentialManager:
    """Manages encrypted credential storage using Windows DPAPI"""

    def __init__(self, credentials_path: Optional[str] = None):
        """
        Initialize credential manager

        Args:
            credentials_path: Path to credentials.json file
                             Defaults to C:/Users/{username}/.claude/.credentials.json
        """
        if credentials_path:
            self.credentials_path = Path(credentials_path)
        else:
            # Default to .claude directory in user home
            home = Path.home()
            self.credentials_path = home / ".claude" / ".credentials.json"

        # Ensure directory exists
        self.credentials_path.parent.mkdir(parents=True, exist_ok=True)

    def _encrypt(self, plaintext: str) -> str:
        """Encrypt string using Windows DPAPI"""
        if not HAS_DPAPI:
            # Fallback: base64 encoding (NOT secure, for testing only)
            return base64.b64encode(plaintext.encode()).decode()

        encrypted_bytes = win32crypt.CryptProtectData(
            plaintext.encode(),
            None,  # Description
            None,  # Optional entropy
            None,  # Reserved
            None,  # Prompt struct
            0      # Flags
        )
        return base64.b64encode(encrypted_bytes).decode()

    def _decrypt(self, encrypted: str) -> str:
        """Decrypt string using Windows DPAPI"""
        if not HAS_DPAPI:
            # Fallback: base64 decoding
            return base64.b64decode(encrypted.encode()).decode()

        encrypted_bytes = base64.b64decode(encrypted.encode())
        _, plaintext_bytes = win32crypt.CryptUnprotectData(
            encrypted_bytes,
            None,  # Optional entropy
            None,  # Reserved
            None,  # Prompt struct
            0      # Flags
        )
        return plaintext_bytes.decode()

    def load_credentials(self) -> Dict[str, str]:
        """
        Load credentials from file

        Returns:
            dict with 'username' and 'password' keys (decrypted)
            Empty dict if file doesn't exist
        """
        if not self.credentials_path.exists():
            return {}

        try:
            with open(self.credentials_path, 'r', encoding='utf-8') as f:
                data = json.load(f)

            result = {}

            # Load CAU portal credentials (for SSO auth)
            if 'cau_portal' in data:
                cau_data = data['cau_portal']
                result['username'] = self._decrypt(cau_data['username'])
                result['password'] = self._decrypt(cau_data['password'])

            return result
        except Exception as e:
            print(f"Error loading credentials: {e}")
            return {}

    def save_credentials(self, creds: Dict[str, str]) -> None:
        """
        Save encrypted credentials to file

        Args:
            creds: Dictionary with 'username' and 'password' keys
        """
        # Load existing data or create new
        if self.credentials_path.exists():
            with open(self.credentials_path, 'r', encoding='utf-8') as f:
                data = json.load(f)
        else:
            data = {}

        # Encrypt and save CAU portal credentials
        if 'username' in creds and 'password' in creds:
            data['cau_portal'] = {
                'username': self._encrypt(creds['username']),
                'password': self._encrypt(creds['password'])
            }

        with open(self.credentials_path, 'w', encoding='utf-8') as f:
            json.dump(data, f, indent=2)

        print(f"Credentials saved to {self.credentials_path}")

    def prompt_for_credentials(self) -> Dict[str, str]:
        """
        Prompt user for credentials and save them

        Returns:
            dict with 'username' and 'password' keys
        """
        print("CAU Portal credentials not found.")
        print("Please enter your CAU portal credentials:")

        username = input("Username (Student ID): ").strip()

        # Use getpass for password input (hidden)
        import getpass
        password = getpass.getpass("Password: ")

        # Save encrypted credentials
        self.save_credentials({'username': username, 'password': password})

        return {'username': username, 'password': password}

    def get_credentials(self) -> Dict[str, str]:
        """
        Get credentials (load from file or prompt if not exists)

        Returns:
            dict with 'username' and 'password' keys
        """
        creds = self.load_credentials()

        if not creds:
            creds = self.prompt_for_credentials()

        return creds


# Convenience function for easy import
def get_credentials(credentials_path: Optional[str] = None) -> Dict[str, str]:
    """
    Get CAU portal credentials (load or prompt)

    Args:
        credentials_path: Optional path to credentials file

    Returns:
        dict with 'username' and 'password' keys
    """
    manager = CredentialManager(credentials_path)
    return manager.get_credentials()
